{
  "identity": {
    "author": "S.H.E.V.K.Y.",
    "email": "hello@shevky.dev",
    "url": "https://shevky.github.io/",
    "themeColor": "#2f8f5b",
    "social": {
      "rss": true,
      "github": "https://github.com/shevky",
      "linkedin": "https://www.linkedin.com/in/fatihtatoglu"
    },
    "name": "S.H.E.V.K.Y."
  },
  "seo": {
    "defaultImage": "https://shevky.github.io/assets/images/shevky-og-cover.png",
    "includeCollections": false,
    "includePaging": false
  },
  "analytics": {
    "enabled": true,
    "gtmId": "",
    "gaId": "G-PGSMZ20YD0",
    "clarityId": ""
  },
  "features": {
    "postOperations": {
      "enabled": false,
      "like": false,
      "dislike": false,
      "comment": false,
      "share": {
        "enabled": false,
        "whatsapp": false,
        "x": false,
        "linkedin": false,
        "facebook": false,
        "copy": false
      }
    },
    "search": false
  },
  "markdown": {
    "highlight": true
  },
  "content": {
    "pagination": {
      "pageSize": 10,
      "segment": {
        "en": "page",
        "tr": "sayfa"
      }
    },
    "languages": {
      "default": "en",
      "supported": [
        "en",
        "tr"
      ],
      "canonical": {
        "en": "/",
        "tr": "/tr/"
      }
    },
    "collections": {}
  },
  "build": {
    "minify": true,
    "debug": false
  },
  "robots": {
    "allow": [
      "/"
    ],
    "disallow": []
  },
  "plugins": [
    "@shevky/plugin-robots-txt",
    "@shevky/plugin-tailwindcss",
    "@shevky/plugin-esbuild",
    "@shevky/plugin-open-graph",
    "@shevky/plugin-rss",
    "@shevky/plugin-sitemap"
  ],
  "pluginConfigs": {
    "shevky-open-graph": {
      "siteName": "S.H.E.V.K.Y. Documentation",
      "publisherType": "organization",
      "defaultTwitterCard": "summary_large_image",
      "defaultImage": "https://shevky.github.io/assets/images/shevky-og-cover.png",
      "exposePageMeta": true,
      "enableSearchAction": false
    },
    "shevky-rss": {
      "feedFilename": "feed.xml",
      "feedTtl": 1440,
      "feedItemCount": 100,
      "includedSchemaTypes": [
        "page"
      ],
      "includedCategories": [
        "docs"
      ]
    },
    "shevky-sitemap": {
      "sitemapFilename": "sitemap.xml"
    }
  }
}
