<footer class="mt-20 border-t border-slate-200/40" role="contentinfo">
  <div class="mx-auto w-full max-w-7xl px-6 md:px-10 py-12 flex flex-col md:flex-row md:items-start md:justify-between gap-8">
    <div class="space-y-4 max-w-md">
      <div class="flex items-center gap-3">
        <img class="footer-mascot" src="/assets/images/shevky-mascot.jpeg" alt="" aria-hidden="true" width="56" height="56" loading="lazy" />
        <div>
          <p class="text-lg font-bold">{{site.title}}</p>
          <p class="text-sm text-muted">{{site.role}}</p>
        </div>
      </div>
      <p class="text-sm text-muted leading-relaxed">{{i18n.footer.tagline}}</p>
      <div class="flex flex-wrap gap-2">
        {{#i18n.footer.tags}}
          <span class="tag-pill">{{text}}</span>
        {{/i18n.footer.tags}}
      </div>
    </div>
    <div class="flex flex-col gap-4">
      <p class="text-xs uppercase tracking-[0.3em] text-muted font-semibold">{{i18n.footer.linksTitle}}</p>
      <div class="flex flex-wrap items-center gap-2">
        {{#i18n.footer.links}}
          <a class="btn-secondary text-sm" href="{{url}}">{{label}}</a>
        {{/i18n.footer.links}}
      </div>
    </div>
  </div>
  <div class="mx-auto w-full max-w-7xl px-6 md:px-10 pb-8 text-xs text-muted flex flex-wrap items-center justify-between gap-4">
    <span>{{i18n.footer.note}}</span>
    <span class="text-xs text-muted">{{i18n.footer.madeWith}}</span>
  </div>
</footer>
