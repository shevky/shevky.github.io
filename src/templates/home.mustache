<section class="section-wrap">
  <div class="grid lg:grid-cols-2 gap-10 items-center">
    <div class="space-y-6 fade-in-up">
      <span class="pill">{{i18n.hero.pill}}</span>
      <h1 class="text-4xl md:text-5xl leading-tight font-bold">{{i18n.hero.title}}</h1>
      <p class="text-lg text-muted leading-relaxed">{{i18n.hero.subtitle}}</p>
      <div class="flex flex-col sm:flex-row flex-wrap gap-3">
        <a class="btn-primary w-full sm:w-auto" href="{{{site.home}}}{{i18n.links.quickStart}}/">
          {{i18n.hero.primaryCta}}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
        </a>
        <a class="btn-secondary w-full sm:w-auto" href="{{{site.home}}}docs/">{{i18n.hero.secondaryCta}}</a>
      </div>
      <p class="text-sm text-muted">{{i18n.hero.note}}</p>
    </div>
    <div class="fade-in-up flex flex-col items-center gap-6">
      <img class="mascot-hero" src="/assets/images/shevky-mascot.jpeg" alt="S.H.E.V.K.Y. mascot" width="120" height="120" loading="eager" />
      <div class="glass glass-strong p-6 md:p-8 w-full">
        <p class="text-sm uppercase tracking-[0.2em] text-muted font-semibold mb-4">{{i18n.hero.summaryTitle}}</p>
        <div class="space-y-4">
          {{#i18n.hero.highlights}}
            <div class="summary-item">
              <h3 class="text-base font-semibold">{{title}}</h3>
              <p class="text-muted text-sm mt-1">{{description}}</p>
            </div>
          {{/i18n.hero.highlights}}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-wrap fade-in-up">
  <div class="flex flex-col gap-4 mb-10">
    <h2 class="section-title">{{i18n.sections.questions.title}}</h2>
    <p class="section-subtitle">{{i18n.sections.questions.subtitle}}</p>
  </div>
  <div class="grid grid-cols-1 gap-5" data-accordion="single">
    {{#i18n.sections.questions.items}}
      <details class="qa-card">
        <summary class="qa-summary">
          <span class="text-lg font-semibold leading-snug">{{question}}</span>
          <span class="qa-icon" aria-hidden="true"></span>
        </summary>
        <div class="qa-body text-muted">
          <p>{{answer}}</p>
        </div>
      </details>
    {{/i18n.sections.questions.items}}
  </div>
</section>

<section class="section-wrap fade-in-up">
  <div class="glass p-8 md:p-10">
    <div class="quickstart-grid">
      <div class="quickstart-text">
        <h2 class="section-title">{{i18n.sections.quickstart.title}}</h2>
        <p class="section-subtitle mt-2">{{i18n.sections.quickstart.subtitle}}</p>
        <ul class="mt-5 space-y-3 text-muted">
          {{#i18n.sections.quickstart.steps}}
            <li class="flex items-start gap-3">
              <svg class="shrink-0 mt-1 text-accent" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>{{text}}</span>
            </li>
          {{/i18n.sections.quickstart.steps}}
        </ul>
      </div>
      <div class="quickstart-media">
        <img class="quickstart-image" src="/assets/images/shevky-process-flow.webp" alt="S.H.E.V.K.Y. process flow" loading="lazy" />
      </div>
      <div class="quickstart-cta">
        <a class="btn-primary w-full" href="{{{site.home}}}{{i18n.links.quickStart}}/">
          {{i18n.sections.quickstart.primaryCta}}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
        </a>
      </div>
      <div class="quickstart-secondary">
        <a class="btn-secondary w-full" href="{{{site.home}}}docs/">{{i18n.sections.quickstart.secondaryCta}}</a>
      </div>
    </div>
  </div>
</section>

<section class="section-wrap fade-in-up">
  <div class="flex flex-col gap-4 mb-10">
    <h2 class="section-title">{{i18n.docs.title}}</h2>
    <p class="section-subtitle">{{i18n.docs.subtitle}}</p>
  </div>
  <nav aria-label="{{i18n.docs.menuTitle}}">
    <div class="grid md:grid-cols-2 gap-5">
      {{#i18n.docs.nav}}
        <a class="docs-card" href="{{{site.home}}}{{slug}}/" title="{{description}}">
          <h3 class="text-lg font-semibold">{{label}}</h3>
          <p class="text-muted mt-2 text-sm">{{description}}</p>
        </a>
      {{/i18n.docs.nav}}
    </div>
  </nav>
</section>
