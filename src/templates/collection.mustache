<section class="section-wrap fade-in-up">
  <div class="glass p-8 md:p-10">
    <p class="text-xs uppercase tracking-[0.25em] text-muted font-semibold">{{i18n.docs.title}}</p>
    <h1 class="text-3xl md:text-4xl font-bold mt-3">
      {{#front.listHeading}}{{front.listHeading}}{{/front.listHeading}}
      {{^front.listHeading}}{{front.title}}{{/front.listHeading}}
    </h1>
    {{#front.description}}<p class="text-muted mt-3 text-lg leading-relaxed">{{front.description}}</p>{{/front.description}}
  </div>
</section>

{{#content}}
  {{#html}}
    <section class="prose max-w-none fade-in-up">
      {{{html}}}
    </section>
  {{/html}}
{{/content}}

<section class="section-wrap fade-in-up">
  {{#listing.hasItems}}
    <div class="grid md:grid-cols-2 gap-5">
      {{#listing.items}}
        <a class="docs-card" href="{{canonical}}" title="{{description}}">
          <p class="text-xs uppercase tracking-[0.25em] text-muted font-semibold">{{categoryLabel}}</p>
          <h2 class="text-lg font-semibold mt-2">{{title}}</h2>
          {{#description}}
            <p class="text-muted mt-2 text-sm">{{description}}</p>
          {{/description}}
        </a>
      {{/listing.items}}
    </div>
  {{/listing.hasItems}}

  {{^listing.hasItems}}
    <p class="text-muted">{{listing.emptyMessage}}</p>
  {{/listing.hasItems}}
</section>
